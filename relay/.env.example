# Copy to .env (gitignored) and fill in real values. Never commit .env.
# The relay auto-loads .env at startup via Node's built-in env-file support.

# OpenAI API key. Put the real secret key here in .env only (this file holds a placeholder).
OPENAI_API_KEY=REPLACE_ME
OPENAI_MODEL=gpt-4.1-mini

# Comma-separated bearer tokens accepted from devices.
DEVICE_TOKENS=dev-local-token-CHANGE_ME

PORT=8787

# Rate / budget guards (in-memory; reset on restart).
RATE_PER_MIN=20
DEVICE_DAILY_CAP=200
GLOBAL_DAILY_CAP=500

# Set to 1 to pause classification (returns silent without calling OpenAI).
KILL_SWITCH=0
