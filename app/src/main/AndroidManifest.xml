<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.ACCESS_NOTIFICATION_POLICY" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <!-- App picker inventory of launchable apps. Play-release strategy (spec §18) is still open;
         usage is isolated behind InstalledAppRepository and never leaves the device. -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />

    <application
        android:name=".ShushlyApp"
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Shushly">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Notification listener: bound by the system; guarded by the system bind permission. -->
        <service
            android:name=".service.listener.ShushlyNotificationListenerService"
            android:exported="true"
            android:label="Shushly notification access"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!-- Owner of the app-owned AutomaticZenRule (Smart Quiet Mode). -->
        <service
            android:name=".service.quietmode.ShushlyConditionProviderService"
            android:exported="true"
            android:label="Shushly Smart Quiet Mode"
            android:permission="android.permission.BIND_CONDITION_PROVIDER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.ConditionProviderService" />
            </intent-filter>
        </service>

        <!-- Quick Settings tile to toggle Smart Quiet Mode. The icon is tinted by the system. -->
        <service
            android:name=".service.tile.QuietModeTileService"
            android:exported="true"
            android:icon="@drawable/ic_qs_quiet"
            android:label="Smart Quiet Mode"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>
    </application>
</manifest>
